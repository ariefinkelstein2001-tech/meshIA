# ----------------------------------------------------------------------------
# meshIA — variables de entorno
# Copia este archivo a .env.local y completa los valores.
# Documentado también en el README (§ Configuración).
# ----------------------------------------------------------------------------

# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Service role: SOLO server-side (ingesta de confianza, cron de resumen).
# Nunca la expongas al browser. No la prefijes con NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# Resend (emails del resumen semanal — Fase 4)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM="meshIA <hola@tudominio.cl>"

# URL pública del sitio (para links en emails y magic link)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Secreto para proteger el endpoint del cron de resumen (Fase 4)
CRON_SECRET=cambia-esto-por-un-secreto-largo
